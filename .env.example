# ===========================================
# RAG Forge — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.

# ---------- Database (Required) ----------
# PostgreSQL connection URL (Supabase or local Docker)
POSTGRES_URL="postgresql://user:password@host:5432/database"

# ---------- LLM Provider Keys ----------
# Set the key for your chosen provider (see src/config/model.config.ts).
# OpenAI is also needed for embeddings regardless of chat provider.
OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
# GOOGLE_GENERATIVE_AI_API_KEY="..."

# ---------- Clerk Auth (Required) ----------
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
